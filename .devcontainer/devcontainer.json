{
  "name": "GitContribute",
  "image": "mcr.microsoft.com/devcontainers/go:1.26-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.26"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/guiyomh/features/golangci-lint:1": {}
  },

  "postCreateCommand": "go mod download && go mod verify && go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "github.vscode-github-actions",
        "editorconfig.editorconfig"
      ],
      "settings": {
        "go.lintTool": "golangci-lint",
        "go.lintFlags": ["--fast"],
        "go.testFlags": ["-short", "-race", "-count=1"],
        "go.testTimeout": "120s",
        "go.coverOnSave": false,
        "go.coverOnSingleTest": true,
        "go.coverOnSingleTestFile": true,
        "go.lintOnSave": "workspace",
        "go.formatTool": "goimports",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        }
      }
    }
  },

  "remoteUser": "vscode"
}
