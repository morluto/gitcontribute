{
  "name": "GitContribute",
  "image": "mcr.microsoft.com/devcontainers/go:1.26-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/golangci-lint:1.0.0": {
      "version": "2.12.2"
    },
    "ghcr.io/devcontainers-extra/features/pre-commit:2.0.18": {
      "version": "4.6.1"
    }
  },

  "postCreateCommand": "go mod download && go mod verify && pre-commit install --install-hooks",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "github.vscode-github-actions",
        "editorconfig.editorconfig"
      ],
      "settings": {
        "go.lintTool": "golangci-lint",
        "go.lintFlags": ["--fast"],
        "go.testFlags": ["-short"],
        "go.testTimeout": "120s",
        "go.coverOnSave": false,
        "go.coverOnSingleTest": true,
        "go.coverOnSingleTestFile": true,
        "go.lintOnSave": "package",
        "go.formatTool": "goimports",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        }
      }
    }
  },

  "remoteUser": "vscode"
}
